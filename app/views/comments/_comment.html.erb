<div class="card mb-3">
  <div class="card-body">
    <h5 class="card-title"> <%= comment.user.email %> </h5>
    <h6 class="card-subtitle mb-2 text-body-secondary"> <%= format_date(comment.created_at) %> </h6>
    <p class="card-text"> <%= comment.body %> </p>
    <%= link_to t('app.button.destroy'), article_comment_path(@article, comment),
            data: { turbo_method: :delete,
            turbo_confirm: "Are you sure?" },
            class: 'btn btn-danger mb-3' if policy(comment).destroy? %>
  </div>
</div>