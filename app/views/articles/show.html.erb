<article class="blog-post">
    <h2 class="h1 blog-post-title"> <%= @article.title %> </h2>
    <p class="blog-post-meta">
        <%= render "article_detail", article: @article %>
    </p>

    <p> <%= @article.body %> </p>

    <%= link_to 'Edit', edit_article_path(@article),
        class: 'btn btn-primary mb-3' if policy(@article).update? %>
        
    <%= link_to 'Back', root_path, class: 'btn btn-secondary mb-3' %>

    <%= link_to 'Delete', article_path(@article),
    data: { turbo_method: :delete,
    turbo_confirm: "Are you sure?" },
    class: 'btn btn-danger mb-3' if policy(@article).destroy? %>

    <h2>Add a comment</h2>
    <%= simple_form_for [@article, @article.comments.build] do |f| %>
        <div class="form-inputs">
            <%= f.input :body, input_html: { rows: 10 } %>
        </div>

    <div class="form-actions">
        <%= f.button :submit, class: 'btn btn-primary' %>
    </div>
    <% end %>
</article>