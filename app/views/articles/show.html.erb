<article class="blog-post">
    <h2 class="h1 blog-post-title"> <%= @article.title %> </h2>
    <p class="blog-post-meta">
        <%= render "article_detail", article: @article %>
    </p>

    <p> <%= @article.body %> </p>

    <%= link_to t('app.button.edit'), edit_article_path(@article),
        class: 'btn btn-primary mb-3' if policy(@article).update? %>
        
    <%= link_to t('app.button.back'), root_path, class: 'btn btn-secondary mb-3' %>

    <%= link_to t('app.button.destroy'), article_path(@article),
    data: { turbo_method: :delete,
    turbo_confirm: "Are you sure?" },
    class: 'btn btn-danger mb-3' if policy(@article).destroy? %>

    <h2 class="mt-3">
			<%= t '.comments' %>
		</h2>
    <%= render @article.comments %>

    <h2><%= t('.add_comment') %></h2>
    <% if policy(:comment).create? %>
        <%= render 'comments/form' %>
    <% else %>
        <p>
					<%= t '.login_create_comment' %>	
        </p>
        <%= link_to t('app.menu.sign_in'), new_user_session_path, class: "btn btn-sm btn-primary" %>
    <% end %>
</article>