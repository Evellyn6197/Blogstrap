<% content_for :title, "Categories" %>
<h1><%= t Category.model_name.human(count: 2) %></h1>
<table class="table table-striped table-hover table-bordered">
  <thead>
    <tr>
      <th><%= t Category.human_attribute_name('name')%></th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <%= link_to t('categories.new.title', model: Category.model_name.human), new_category_path, class: "btn btn-success mb-3" if policy(:category).new? %>
    <% @categories.each do |category| %>
      <tr>
        <td><%= category.name %></td>
        <td>
          <%= link_to t('app.button.edit'), edit_category_path(category), class: "text-decoration-none" if policy(category).edit? %>
          <%= link_to t('app.button.destroy'), category_path(category),
          data: { turbo_method: :delete,
          turbo_confirm: t('app.message.confirm_destroy') },
          class: "text-decoration-none" if policy(category).destroy? %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

